APP_NAME="ENCG ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Casablanca
APP_URL=http://localhost
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# ──────────────────────────────────────────
# Frontend
# ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────
# Database — PostgreSQL
# ──────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=encg_erp
DB_USERNAME=encg
DB_PASSWORD=secret
DB_SCHEMA=public

# ──────────────────────────────────────────
# Cache / Session / Queue
# ──────────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
QUEUE_CONNECTION=redis

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ──────────────────────────────────────────
# Mail — Mailpit (local)
# ──────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@encg-fes.ma"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────
# MinIO (S3-compatible)
# ──────────────────────────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=encg-documents
AWS_BUCKET_PRIVATE=encg-private
AWS_URL=http://localhost:9000
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ──────────────────────────────────────────
# Laravel Sanctum
# ──────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000

# ──────────────────────────────────────────
# Laravel Reverb (WebSocket)
# ──────────────────────────────────────────
BROADCAST_DRIVER=reverb
REVERB_APP_ID=encg-erp-app
REVERB_APP_KEY=encg-reverb-key
REVERB_APP_SECRET=encg-reverb-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# ──────────────────────────────────────────
# Laravel Horizon
# ──────────────────────────────────────────
HORIZON_PREFIX=encg_horizon:

# ──────────────────────────────────────────
# AI Driver
# NOTE: For production, DO NOT use the `stub` driver. Set this to a
# supported provider (e.g., `gemini`) in your production `.env` file.
# Leaving this empty in the example forces an explicit choice during
# deployment and prevents accidental use of a local stub in production.
AI_DRIVER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048

# ──────────────────────────────────────────
# Multi-Tenant
# ──────────────────────────────────────────
TENANT_RESOLVER=subdomain
DEFAULT_INSTITUTION_ID=1

# ──────────────────────────────────────────
# PDF Generation
# ──────────────────────────────────────────
PDF_ENGINE=dompdf
PDF_PAPER_SIZE=A4

# ──────────────────────────────────────────
# Moroccan Law 09-08 Compliance
# ──────────────────────────────────────────
AUDIT_ENABLED=true
DATA_RETENTION_DAYS=3650
CONSENT_REQUIRED=true

# ──────────────────────────────────────────
# Security
# ──────────────────────────────────────────
BCRYPT_ROUNDS=12
TWO_FACTOR_ISSUER="ENCG ERP"
